      <aliases enabled='yes' />
      <column caption='Age' datatype='integer' name='[Calculation_0910459229216768]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR(TODAY()) - [Year_Birth]' />
      </column>
      <column caption='Total Purchase Made ' datatype='integer' name='[Calculation_0910459236286465]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[NumWebPurchases]+[NumStorePurchases]+[NumCatalogPurchases]' />
      </column>
      <column caption='Registration Year' datatype='integer' name='[Calculation_1598478396133376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Dt_Customer])' />
      </column>
      <column caption='Customer Count' datatype='integer' name='[Calculation_1598478400479233]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Complain Rate' datatype='real' name='[Calculation_1598478469050374]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Complain]) / COUNTD([ID])' />
      </column>
      <column caption='Cust who Complain' datatype='integer' name='[Calculation_1598478472626183]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Complain] = 1 THEN [ID] END)' />
      </column>
      <column caption='Customer Who Responded' datatype='integer' name='[Calculation_1598478473314312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Response] = 1 THEN [ID] END)' />
      </column>
